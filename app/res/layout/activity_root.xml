<?xml version="1.0" encoding="utf-8"?>
<!--
╔══════════════════════════════════════════════════════════╗
║  activity_root.xml                                        ║
║  React equivalent: RootLayout                             ║
║                                                           ║
║  JSX → XML mapping:                                       ║
║  min-h-screen                   → layout_height=match_parent ║
║  bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50 ║
║                                 → @drawable/bg_root_gradient ║
║  font-['Inter',sans-serif]       → (applied in styles.xml)  ║
║  mx-auto max-w-md               → constraintWidth_max 448dp ║
║  <Outlet />                     → <FragmentContainerView>   ║
╚══════════════════════════════════════════════════════════╝
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_root_gradient">

    <!--
        Center column — mirrors  mx-auto max-w-md min-h-screen
        ┌──────────────────────────────────────┐
        │  phone: fills 100% width             │
        │  tablet: caps at 448 dp, centered    │
        └──────────────────────────────────────┘
        Acts as the <Outlet /> host.
        Replace with FragmentContainerView if using Navigation Component.
    -->
    <FrameLayout
        android:id="@+id/rootContainer"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintWidth_max="448dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>