<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-feature android:name="android.hardware.camera"
        android:required="true"/>

    <application

        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/star_plain_foreground"
        android:label="STARS"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.OMRScanner">

        <activity android:name=".ui.ResultActivity"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".ui.PreviewActivity"/>
        <activity android:name=".ui.LrnErrorActivity"
            android:label="LRN Error"
            android:theme="@style/Theme.OMRScanner" />
        <activity android:name=".camera.CameraActivity"
            android:screenOrientation="portrait"/>
        <activity android:name=".DashboardActivity"/>

        <!-- QR Scanner -->
        <activity android:name=".camera.QrScannerActivity"/>

        <!-- Beta expiry gate — launched when APK beta period has ended -->
        <activity
            android:name=".BetaExpiredActivity"
            android:label="STARS"
            android:theme="@style/Theme.OMRScanner" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- CSV File Manager -->
        <activity
            android:name=".ui.CSVFileActivity"
            android:label="My Files"
            android:theme="@style/Theme.OMRScanner" />

        <!-- Full Image Viewer -->
        <activity
            android:name=".ui.FullImageViewerActivity"
            android:label="View Image"
            android:theme="@style/Theme.OMRScanner" />

        <activity
            android:name=".ui.ScanDetailActivity"
            android:label="Scan Detail"
            android:theme="@style/Theme.OMRScanner" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>