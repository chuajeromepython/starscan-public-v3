<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera preview card — same style as OMR scanner -->
    <FrameLayout
        android:id="@+id/qrPreviewCard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="72dp"
        android:layout_marginBottom="192dp"
        android:background="@drawable/bg_camera_preview"
        android:clipToOutline="true">

        <androidx.camera.view.PreviewView
            android:id="@+id/qrPreviewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fillCenter"/>

        <!-- Status bar at bottom of preview -->
        <LinearLayout
            android:id="@+id/qrStatusBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#B3000000"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/qrStatusIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_qr_scan"
                app:tint="#FFC107"/>

            <TextView
                android:id="@+id/tvQrResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Point camera at a QR code"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_medium"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Floating hint -->
        <TextView
            android:id="@+id/tvFloatingHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_floating_hint"
            android:text="Point camera at a QR code"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium"
            android:gravity="center"
            android:maxWidth="280dp"
            android:elevation="4dp"/>

    </FrameLayout>

    <!-- Header — same style as OMR scanner -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <FrameLayout
            android:id="@+id/btnCloseQr"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_cam_btn_white"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Close">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                app:tint="#FFFFFF"/>
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="QR Scanner"
            android:textColor="#E6FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <!-- Flash button placeholder to balance the header -->
        <FrameLayout
            android:id="@+id/btnQrFlash"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_cam_btn_white"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Toggle flash">
            <ImageView
                android:id="@+id/iconQrFlash"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_flash"
                app:tint="#FFFFFF"/>
        </FrameLayout>

    </LinearLayout>

    <!-- Bottom controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_fade"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Scanning automatically..."
            android:textColor="#99FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium"/>

    </LinearLayout>

</FrameLayout>