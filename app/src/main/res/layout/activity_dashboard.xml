<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1117"
    android:fitsSystemWindows="true">

    <!-- ═══ Top Bar ═══ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="#161b22"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back button (hidden on home) -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:tint="#f0a500"
            android:contentDescription="Back"
            android:visibility="gone"
            android:layout_marginEnd="8dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/topBarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⬡ OMR SCANNER"
            android:textColor="#e6edf3"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:ellipsize="end" />

        <!-- Badge / subtitle text -->
        <TextView
            android:id="@+id/topBarBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 classes"
            android:textColor="#8b949e"
            android:textSize="11sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- ═══ Content Area ═══ -->
    <FrameLayout
        android:id="@+id/contentFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ══════════════════════════════════════════════════ -->
        <!-- SCREEN 1: HOME — List of class folders            -->
        <!-- ══════════════════════════════════════════════════ -->
        <ScrollView
            android:id="@+id/screenHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="100dp">

                <!-- Empty state -->
                <LinearLayout
                    android:id="@+id/homeEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp"
                    android:layout_marginTop="60dp"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📁"
                        android:textSize="52sp"
                        android:alpha="0.5" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No class folders yet"
                        android:textColor="#8b949e"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap + to create your first class"
                        android:textColor="#8b949e"
                        android:textSize="13sp"
                        android:alpha="0.7"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Class folders list container -->
                <LinearLayout
                    android:id="@+id/homeClassList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════ -->
        <!-- SCREEN 2: CLASS — List of activities in a class   -->
        <!-- ══════════════════════════════════════════════════ -->
        <ScrollView
            android:id="@+id/screenClass"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="100dp">

                <!-- Teacher info label -->
                <TextView
                    android:id="@+id/classTeacherLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teacher: Unknown"
                    android:textColor="#8b949e"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="16dp" />

                <!-- Empty state -->
                <LinearLayout
                    android:id="@+id/classEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp"
                    android:layout_marginTop="40dp"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋"
                        android:textSize="52sp"
                        android:alpha="0.5" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No activities yet"
                        android:textColor="#8b949e"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap + to add an activity"
                        android:textColor="#8b949e"
                        android:textSize="13sp"
                        android:alpha="0.7"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Activities list container -->
                <LinearLayout
                    android:id="@+id/classActivityList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════ -->
        <!-- SCREEN 3: ACTIVITY — Scans + Start Scanning       -->
        <!-- ══════════════════════════════════════════════════ -->
        <ScrollView
            android:id="@+id/screenActivity"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="100dp">

                <!-- Master CSV bar (shown when scans exist) -->
                <LinearLayout
                    android:id="@+id/masterCsvBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/master_csv_bar_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/masterCsvLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📊 _Master.csv · 0 entries"
                        android:textColor="#f0a500"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/btnExportMaster"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↓ Export"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:background="@drawable/export_button_bg"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Scan CTA Card -->
                <LinearLayout
                    android:id="@+id/scanCtaCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="28dp"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/scan_cta_bg"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📷"
                        android:textSize="40sp"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start Scanning"
                        android:textColor="#e6edf3"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/scanCtaSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ZPH30 · 30 items"
                        android:textColor="#8b949e"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Section Header (Scanned Papers) -->
                <LinearLayout
                    android:id="@+id/scansHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SCANNED PAPERS"
                        android:textColor="#8b949e"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/scansTotalCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 total"
                        android:textColor="#f0a500"
                        android:textSize="11sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Scans list container -->
                <LinearLayout
                    android:id="@+id/activityScanList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone" />

                <!-- Empty state for scans -->
                <LinearLayout
                    android:id="@+id/activityScansEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="30dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🗒"
                        android:textSize="52sp"
                        android:alpha="0.5" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No scans yet"
                        android:textColor="#8b949e"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap 'Start Scanning' to begin"
                        android:textColor="#8b949e"
                        android:textSize="13sp"
                        android:alpha="0.7"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

    <!-- ═══ FAB Button ═══ -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:contentDescription="Add"
        android:src="@android:drawable/ic_input_add"
        app:tint="#000000"
        app:backgroundTint="#f0a500"
        app:fabSize="normal"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>