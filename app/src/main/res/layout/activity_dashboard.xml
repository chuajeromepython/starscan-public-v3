<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fitsSystemWindows="true">

    <!-- ═══ Header Card ═══ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/headerCard"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:cardBackgroundColor="#0038A8"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp">

            <ImageView
                android:id="@+id/logo"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:contentDescription="App Logo"
                android:src="@drawable/sagotsuri"
                android:background="@drawable/logo_bg"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnMenu"
                app:layout_constraintStart_toEndOf="@+id/logo"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/topBarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SagotSuri"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/topBarBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 classes"
                    android:textColor="#CBD5E1"
                    android:textSize="12sp" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_menu"
                android:contentDescription="Menu"
                app:tint="#FFFFFF"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ═══ Content Card ═══ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/contentCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:strokeColor="#E2E8F0"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerCard">

        <!--
            The content card now uses a vertical LinearLayout so the breadcrumb bar
            sits above the screens and the screens fill the remaining space.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- ═══ BREADCRUMB BAR ═══
                 Mimics Google Drive's path bar.
                 GONE on home screen. VISIBLE on class/activity screens.
                 Shows:  ‹back›  Classes  ›  Grade 10 — Sec A  ›  Math Quiz
                 btnBack id lives here — Java listener unchanged.
                 breadcrumbRoot tapping jumps straight to home (wire up in Java below).
            -->
            <LinearLayout
                android:id="@+id/breadcrumbBar"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="12dp"
                android:background="#F8FAFC"
                android:visibility="gone">

                <!-- Back arrow -->
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#0038A8"
                    android:contentDescription="Back"
                    android:padding="8dp" />

                <!-- Scrollable path so long class/activity names don't clip -->
                <HorizontalScrollView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- "Classes" root — always shown, tappable to jump to home -->
                        <TextView
                            android:id="@+id/breadcrumbRoot"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Classes"
                            android:textColor="#0038A8"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:paddingStart="4dp"
                            android:paddingEnd="4dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp" />

                        <!-- Separator ›  between root and class -->
                        <TextView
                            android:id="@+id/breadcrumbSep1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" › "
                            android:textColor="#94A3B8"
                            android:textSize="14sp"
                            android:visibility="gone" />

                        <!-- Class name — shown on Class + Activity screens, tappable on Activity screen -->
                        <TextView
                            android:id="@+id/breadcrumbClass"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#0038A8"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:paddingStart="4dp"
                            android:paddingEnd="4dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:visibility="gone" />

                        <!-- Separator › between class and activity -->
                        <TextView
                            android:id="@+id/breadcrumbSep2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" › "
                            android:textColor="#94A3B8"
                            android:textSize="14sp"
                            android:visibility="gone" />

                        <!-- Activity name — shown only on Activity screen, current level so not tappable -->
                        <TextView
                            android:id="@+id/breadcrumbActivity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#1E293B"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif"
                            android:paddingStart="4dp"
                            android:paddingEnd="4dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:visibility="gone" />

                    </LinearLayout>
                </HorizontalScrollView>

            </LinearLayout>

            <!-- Hairline divider below breadcrumb -->
            <View
                android:id="@+id/breadcrumbDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E2E8F0"
                android:visibility="gone" />

            <!-- Screens fill the rest of the card -->
            <FrameLayout
                android:id="@+id/contentFrame"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipChildren="false">

                <!-- ══════════════════════════════════════════════════ -->
                <!-- SCREEN 1: HOME                                     -->
                <!-- ══════════════════════════════════════════════════ -->
                <ScrollView
                    android:id="@+id/screenHome"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true"
                    android:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:paddingBottom="100dp">

                        <LinearLayout
                            android:id="@+id/homeEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="40dp"
                            android:layout_marginTop="60dp"
                            android:visibility="visible">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📁"
                                android:textSize="52sp"
                                android:alpha="0.5" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No class folders yet"
                                android:textColor="#64748B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="12dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tap + to create your first class"
                                android:textColor="#94A3B8"
                                android:textSize="13sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/homeClassList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone" />

                    </LinearLayout>
                </ScrollView>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- SCREEN 2: CLASS                                    -->
                <!-- ══════════════════════════════════════════════════ -->
                <ScrollView
                    android:id="@+id/screenClass"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:paddingBottom="100dp">

                        <TextView
                            android:id="@+id/classTeacherLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Teacher: Unknown"
                            android:textColor="#64748B"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:id="@+id/classEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="40dp"
                            android:layout_marginTop="40dp"
                            android:visibility="visible">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📋"
                                android:textSize="52sp"
                                android:alpha="0.5" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No activities yet"
                                android:textColor="#64748B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="12dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tap + to add an activity"
                                android:textColor="#94A3B8"
                                android:textSize="13sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/classActivityList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone" />

                    </LinearLayout>
                </ScrollView>

                <!-- ══════════════════════════════════════════════════ -->
                <!-- SCREEN 3: ACTIVITY                                 -->
                <!-- ══════════════════════════════════════════════════ -->
                <ScrollView
                    android:id="@+id/screenActivity"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:paddingBottom="100dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/masterCsvBar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:cardBackgroundColor="#F0F7FF"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#0038A8"
                            app:strokeWidth="1dp"
                            android:visibility="gone">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:padding="12dp">

                                <TextView
                                    android:id="@+id/masterCsvLabel"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="📊 _Master.csv · 0 entries"
                                    android:textColor="#0038A8"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-medium" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnExportMaster"
                                    style="@style/Widget.Material3.Button.UnelevatedButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="36dp"
                                    android:text="↓ Export"
                                    android:textColor="#FFFFFF"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    app:backgroundTint="#0038A8"
                                    app:cornerRadius="8dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <androidx.cardview.widget.CardView
                            android:id="@+id/scanCtaCard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?android:attr/selectableItemBackground"
                            app:cardBackgroundColor="#0038A8"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="4dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="28dp">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:layout_marginBottom="10dp"
                                    android:contentDescription="Camera Icon"
                                    android:src="@drawable/ic_camera" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Start Scanning"
                                    android:textColor="#FFFFFF"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-medium"
                                    android:layout_marginBottom="6dp" />

                                <TextView
                                    android:id="@+id/scanCtaSub"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ZPH30 · 30 items"
                                    android:textColor="#E0E7FF"
                                    android:textSize="13sp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:id="@+id/scansHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="SCANNED PAPERS"
                                android:textColor="#64748B"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/scansTotalCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 total"
                                android:textColor="#CE1126"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/activityScanList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/activityScansEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="30dp"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🗒"
                                android:textSize="52sp"
                                android:alpha="0.5" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No scans yet"
                                android:textColor="#64748B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="12dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tap 'Start Scanning' to begin"
                                android:textColor="#94A3B8"
                                android:textSize="13sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                    </LinearLayout>
                </ScrollView>

            </FrameLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ═══ Footer ═══ -->
    <TextView
        android:id="@+id/footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:fontFamily="sans-serif-medium"
        android:text="© 2026 OMR Scanner"
        android:textColor="#94A3B8"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ═══ FAB Button ═══ -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:contentDescription="Add"
        android:src="@android:drawable/ic_input_add"
        app:tint="#FFFFFF"
        app:backgroundTint="#CE1126"
        app:fabSize="normal"
        app:elevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>