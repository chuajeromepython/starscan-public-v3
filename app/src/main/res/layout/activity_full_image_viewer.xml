<?xml version="1.0" encoding="utf-8"?>
<!-- Full Image Viewer Layout — aligned to dashboard design system -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- Zoomable Image View (full screen behind everything) -->
    <com.example.omrscanner.ui.widgets.ZoomableImageView
        android:id="@+id/fullScreenImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/full_screen_exam_paper_image" />

    <!-- ═══ Top Bar (mirrors dashboard header style) ═══ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topBarCard"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        app:cardBackgroundColor="#CC0038A8"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp">

            <!-- Close Button (Top Left) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClose"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/close_image_viewer"
                app:icon="@drawable/ic_close"
                app:iconTint="#FFFFFF"
                app:cornerRadius="24dp"
                android:backgroundTint="#33FFFFFF"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Screen Title -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Image Viewer"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_black"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginStart="8dp"
                app:layout_constraintStart_toEndOf="@id/btnClose"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ═══ Image Info Card (Bottom) — mirrors dashboard content card style ═══ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/infoCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#F2FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:strokeColor="#E2E8F0"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Blue accent bar -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_marginBottom="14dp"
                android:background="#0038A8"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvFilename"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/filename"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/poppins_medium" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/date"
                android:textSize="14sp"
                android:textColor="#64748B"
                android:fontFamily="@font/poppins" />

            <!-- Footer credit, matching dashboard footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="© 2026 OMR Scanner"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textAlignment="center"
                android:fontFamily="@font/poppins_medium" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>