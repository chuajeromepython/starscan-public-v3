<?xml version="1.0" encoding="utf-8"?>
<!--
╔══════════════════════════════════════════════════════════════╗
║  activity_scan_detail.xml                                     ║
║  Unified design — matches activity_dashboard.xml              ║
║                                                               ║
║  Extracted Answers Card:                                      ║
║  • Static preview shows items 1-20 (2 cols × 10 rows)        ║
║  • Java replaces this with answersContainer at runtime        ║
║  • Row pattern: zebra stripe #F8FAFC / #FFFFFF                ║
║  • Number: 36dp wide, #0038A8 bold                            ║
║  • Answer: #1E293B bold                                       ║
║  • Center divider: 1dp #E2E8F0                                ║
╚══════════════════════════════════════════════════════════════╝
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_root_gradient"
    android:fitsSystemWindows="true">

    <!-- ═══ PAGE HEADER ═══ -->
    <FrameLayout
        android:id="@+id/headerCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View android:layout_width="128dp" android:layout_height="128dp"
            android:layout_gravity="top|end" android:layout_marginTop="-30dp"
            android:layout_marginEnd="-20dp" android:background="@drawable/shape_circle_white"
            android:alpha="0.05" />
        <View android:layout_width="96dp" android:layout_height="96dp"
            android:layout_gravity="bottom|start" android:layout_marginBottom="-10dp"
            android:layout_marginStart="-15dp" android:background="@drawable/shape_circle_white"
            android:alpha="0.05" />
        <View android:layout_width="64dp" android:layout_height="64dp"
            android:layout_gravity="top|end" android:layout_marginTop="32dp"
            android:layout_marginEnd="80dp" android:background="@drawable/shape_circle_white"
            android:alpha="0.03" />

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_gravity="center_vertical" android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton android:id="@+id/btnBack"
                android:layout_width="48dp" android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back" android:contentDescription="Back"
                android:padding="8dp" app:tint="#FFFFFF" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:layout_marginStart="8dp" android:layout_marginEnd="8dp">
                <TextView android:id="@+id/topBarTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Scan Details" android:textColor="#FFFFFF"
                    android:textSize="18sp" android:textStyle="bold"
                    android:fontFamily="sans-serif-black" android:singleLine="true"
                    android:ellipsize="end" />
                <TextView android:id="@+id/topBarBadge"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Review &amp; Edit" android:textColor="#BFDBFE"
                    android:textSize="12sp" android:layout_marginTop="2dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton android:id="@+id/btnEditToggle"
                style="@style/Widget.Material3.Button.UnelevatedButton"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="EDIT" android:textAllCaps="true" android:textColor="#0038A8"
                android:textSize="13sp" android:textStyle="bold"
                app:backgroundTint="#FFFFFF" app:cornerRadius="18dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- ═══ FLOATING CONTENT CARD ═══ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/contentCard"
        android:layout_width="0dp" android:layout_height="0dp"
        android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
        android:layout_marginTop="-40dp" android:layout_marginBottom="0dp"
        app:cardBackgroundColor="#F2FFFFFF" app:cardCornerRadius="24dp"
        app:cardElevation="6dp" app:strokeColor="#33FFFFFF" app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/headerCard"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:overScrollMode="never" android:scrollbars="none"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp"
                android:paddingBottom="80dp">

                <!-- ══ IMAGE PREVIEW CARD ══ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent" android:layout_height="260dp"
                    android:layout_marginBottom="16dp" app:cardBackgroundColor="#1E293B"
                    app:cardCornerRadius="20dp" app:cardElevation="3dp"
                    app:strokeColor="#E2E8F0" app:strokeWidth="1dp">
                    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <ImageView android:id="@+id/scanImage"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            android:layout_gravity="center" android:adjustViewBounds="true"
                            android:contentDescription="Scanned Image" android:scaleType="fitCenter" />
                        <TextView android:id="@+id/imgPlaceholder"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="No Image Available" android:textColor="#94A3B8"
                            android:textSize="14sp" android:layout_gravity="center"
                            android:visibility="gone" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ══ METADATA CARD ══ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp" app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp" app:cardElevation="1dp"
                    app:strokeColor="#F1F5F9" app:strokeWidth="1dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="20dp">

                        <View android:layout_width="40dp" android:layout_height="4dp"
                            android:layout_marginBottom="16dp" android:background="#0038A8"
                            android:layout_gravity="start" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="STUDENT LRN" android:textColor="#64748B"
                            android:textSize="11sp" android:textStyle="bold"
                            android:letterSpacing="0.1" android:fontFamily="sans-serif-medium" />

                        <EditText android:id="@+id/etLrn"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" android:background="@null"
                            android:enabled="false" android:hint="No LRN" android:inputType="text"
                            android:maxLines="1" android:ellipsize="end"
                            android:textColor="#1E293B" android:textColorHint="#CBD5E1"
                            android:textSize="16sp" android:fontFamily="sans-serif-medium" />

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:layout_marginTop="14dp" android:layout_marginBottom="14dp"
                            android:background="#F1F5F9" />

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Score -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <FrameLayout android:layout_width="32dp" android:layout_height="32dp"
                                    android:background="@drawable/bg_stat_violet" android:layout_marginBottom="8dp">
                                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                        android:layout_gravity="center" android:src="@drawable/ic_clipboard_list"
                                        app:tint="#7C3AED" />
                                </FrameLayout>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="SCORE" android:textColor="#64748B" android:textSize="11sp"
                                    android:textStyle="bold" android:letterSpacing="0.1"
                                    android:fontFamily="sans-serif-medium" />
                                <TextView android:id="@+id/tvScore"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp" android:text="0/0"
                                    android:textColor="#0038A8" android:textSize="22sp"
                                    android:textStyle="bold" android:fontFamily="sans-serif-black" />
                            </LinearLayout>

                            <View android:layout_width="1dp" android:layout_height="match_parent"
                                android:layout_marginEnd="16dp" android:background="#F1F5F9" />

                            <!-- Timestamp -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <FrameLayout android:layout_width="32dp" android:layout_height="32dp"
                                    android:background="@drawable/bg_stat_blue" android:layout_marginBottom="8dp">
                                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                        android:layout_gravity="center" android:src="@drawable/ic_scan_line"
                                        app:tint="#2563EB" />
                                </FrameLayout>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="TIMESTAMP" android:textColor="#64748B" android:textSize="11sp"
                                    android:textStyle="bold" android:letterSpacing="0.1"
                                    android:fontFamily="sans-serif-medium" />
                                <TextView android:id="@+id/tvDate"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp" android:text="—"
                                    android:textColor="#1E293B" android:textSize="14sp"
                                    android:fontFamily="sans-serif" />
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ══════════════════════════════════════════════
                     EXTRACTED ANSWERS CARD
                     ══════════════════════════════════════════════
                     Static XML shows items 1-20 as a design preview
                     (2 columns × 10 rows, zebra striped).
                     At runtime Java clears answersContainer and
                     re-inflates the same row structure for real data.
                ═══════════════════════════════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="1dp"
                    app:strokeColor="#F1F5F9"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Card header row -->
                        <LinearLayout
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <View android:layout_width="4dp" android:layout_height="18dp"
                                android:layout_marginEnd="10dp" android:background="#0038A8" />

                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="EXTRACTED ANSWERS"
                                android:textColor="#1E293B" android:textSize="13sp"
                                android:textStyle="bold" android:letterSpacing="0.05"
                                android:fontFamily="sans-serif-black" />

                            <TextView android:id="@+id/tvAnswerCount"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="20 items" android:textColor="#2563EB"
                                android:textSize="11sp" android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:background="@drawable/bg_stat_blue"
                                android:paddingStart="8dp" android:paddingEnd="8dp"
                                android:paddingTop="3dp" android:paddingBottom="3dp" />
                        </LinearLayout>

                        <!-- Hairline divider -->
                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:layout_marginBottom="10dp" android:background="#F1F5F9" />

                        <!-- Column header labels -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="4dp">

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="horizontal"
                                android:gravity="center_vertical" android:paddingStart="4dp">
                                <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                    android:text="ITEM" android:textColor="#94A3B8" android:textSize="10sp"
                                    android:textStyle="bold" android:letterSpacing="0.08"
                                    android:fontFamily="sans-serif-medium" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="ANSWER" android:textColor="#94A3B8" android:textSize="10sp"
                                    android:textStyle="bold" android:letterSpacing="0.08"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>

                            <View android:layout_width="1dp" android:layout_height="match_parent"
                                android:background="#E2E8F0" />

                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="horizontal"
                                android:gravity="center_vertical" android:paddingStart="8dp">
                                <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                    android:text="ITEM" android:textColor="#94A3B8" android:textSize="10sp"
                                    android:textStyle="bold" android:letterSpacing="0.08"
                                    android:fontFamily="sans-serif-medium" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="ANSWER" android:textColor="#94A3B8" android:textSize="10sp"
                                    android:textStyle="bold" android:letterSpacing="0.08"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Column header underline -->
                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:layout_marginBottom="2dp" android:background="#EFF6FF" />

                        <!--
                        ╔══════════════════════════════════════════╗
                        ║  ANSWERS CONTAINER (Java populates this) ║
                        ║  Each chunk = horizontal LinearLayout:   ║
                        ║  leftCol (weight=1) | 1dp divider |      ║
                        ║  rightCol (weight=1)                     ║
                        ║  Items per col = 10, rows = 36dp tall    ║
                        ║  Zebra: odd=#F8FAFC, even=#FFFFFF        ║
                        ╚══════════════════════════════════════════╝
                        Static preview below mirrors exact runtime structure.
                        Java should: answersContainer.removeAllViews()
                        then re-add chunks using the same row XML.
                        -->
                        <LinearLayout
                            android:id="@+id/answersContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- ═══ CHUNK 1: items 1-10 (left) | 11-20 (right) ═══ -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <!-- Left column: items 1-10 -->
                                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                                    android:layout_height="wrap_content" android:orientation="vertical">

                                    <!-- Row 1 — stripe #F8FAFC -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                                        android:orientation="horizontal" android:gravity="center_vertical"
                                        android:paddingStart="4dp" android:paddingEnd="4dp" android:background="#F8FAFC">
                                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                            android:text="1" android:textColor="#0038A8" android:textSize="11sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="A" android:textColor="#1E293B" android:textSize="14sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-black" />
                                    </LinearLayout>
                                    <!-- Row 2 — stripe #FFFFFF -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                                        android:orientation="horizontal" android:gravity="center_vertical"
                                        android:paddingStart="4dp" android:paddingEnd="4dp" android:background="#FFFFFF">
                                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                            android:text="2" android:textColor="#0038A8" android:textSize="11sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="B" android:textColor="#1E293B" android:textSize="14sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-black" />
                                    </LinearLayout>
                                    <!-- Row 3 -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                                        android:orientation="horizontal" android:gravity="center_vertical"
                                        android:paddingStart="4dp" android:paddingEnd="4dp" android:background="#F8FAFC">
                                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                            android:text="3" android:textColor="#0038A8" android:textSize="11sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="C" android:textColor="#1E293B" android:textSize="14sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-black" />
                                    </LinearLayout>
                                    <!-- Row 4 -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                                        android:orientation="horizontal" android:gravity="center_vertical"
                                        android:paddingStart="4dp" android:paddingEnd="4dp" android:background="#FFFFFF">
                                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                            android:text="4" android:textColor="#0038A8" android:textSize="11sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="A" android:textColor="#1E293B" android:textSize="14sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-black" />
                                    </LinearLayout>
                                    <!-- Row 5 -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                                        android:orientation="horizontal" android:gravity="center_vertical"
                                        android:paddingStart="4dp" android:paddingEnd="4dp" android:background="#F8FAFC">
                                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                            android:text="5" android:textColor="#0038A8" android:textSize="11sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="D" android:textColor="#1E293B" android:textSize="14sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-black" />
                                    </LinearLayout>
                                    <!-- Row 6 -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                                        android:orientation="horizontal" android:gravity="center_vertical"
                                        android:paddingStart="4dp" android:paddingEnd="4dp" android:background="#FFFFFF">
                                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                            android:text="6" android:textColor="#0038A8" android:textSize="11sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="B" android:textColor="#1E293B" android:textSize="14sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-black" />
                                    </LinearLayout>
                                    <!-- Row 7 -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                                        android:orientation="horizontal" android:gravity="center_vertical"
                                        android:paddingStart="4dp" android:paddingEnd="4dp" android:background="#F8FAFC">
                                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                            android:text="7" android:textColor="#0038A8" android:textSize="11sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="C" android:textColor="#1E293B" android:textSize="14sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-black" />
                                    </LinearLayout>
                                    <!-- Row 8 -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                                        android:orientation="horizontal" android:gravity="center_vertical"
                                        android:paddingStart="4dp" android:paddingEnd="4dp" android:background="#FFFFFF">
                                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                            android:text="8" android:textColor="#0038A8" android:textSize="11sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="A" android:textColor="#1E293B" android:textSize="14sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-black" />
                                    </LinearLayout>
                                    <!-- Row 9 -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                                        android:orientation="horizontal" android:gravity="center_vertical"
                                        android:paddingStart="4dp" android:paddingEnd="4dp" android:background="#F8FAFC">
                                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                            android:text="9" android:textColor="#0038A8" android:textSize="11sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="D" android:textColor="#1E293B" android:textSize="14sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-black" />
                                    </LinearLayout>
                                    <!-- Row 10 -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                                        android:orientation="horizontal" android:gravity="center_vertical"
                                        android:paddingStart="4dp" android:paddingEnd="4dp" android:background="#FFFFFF">
                                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                            android:text="10" android:textColor="#0038A8" android:textSize="11sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="B" android:textColor="#1E293B" android:textSize="14sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-black" />
                                    </LinearLayout>

                                </LinearLayout>

                                <!-- Center divider -->
                                <View android:layout_width="1dp" android:layout_height="match_parent"
                                    android:background="#E2E8F0" />

                                <!-- Right column: items 11-20 -->
                                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                                    android:layout_height="wrap_content" android:orientation="vertical">

                                    <!-- Row 11 -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                                        android:orientation="horizontal" android:gravity="center_vertical"
                                        android:paddingStart="8dp" android:paddingEnd="4dp" android:background="#F8FAFC">
                                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                            android:text="11" android:textColor="#0038A8" android:textSize="11sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="C" android:textColor="#1E293B" android:textSize="14sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-black" />
                                    </LinearLayout>
                                    <!-- Row 12 -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="36dp"
                                        android:orientation="horizontal" android:gravity="center_vertical"
                                        android:paddingStart="8dp" android:paddingEnd="4dp" android:background="#FFFFFF">
                                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                                            android:text="12" android:textColor="#0038A8" android:textSize="11sp"
                                            android:textStyle="bold" android:fontFamily="sans-serif-medium" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="A" android:textColor="#1E293B" android:textSize="14sp"
