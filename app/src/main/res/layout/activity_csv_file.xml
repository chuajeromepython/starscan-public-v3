<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#FAFAFA">

    <!-- Success Icon -->
    <TextView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="✓"
        android:textSize="60sp"
        android:textColor="#4CAF50"
        android:gravity="center"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:layout_marginBottom="24dp"/>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CSV File Ready"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="8dp"/>

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your OMR results have been exported"
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_marginBottom="32dp"/>

    <!-- File Info Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#FFFFFF">

            <TextView
                android:id="@+id/tvFilePath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="File: OMR_Results_20240101.csv"
                android:textSize="14sp"
                android:textColor="#212121"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvFileInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Size: 2.5 KB"
                android:textSize="12sp"
                android:textColor="#757575"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Share Button -->
    <Button
        android:id="@+id/btnShare"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Share CSV File"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#2196F3"
        android:layout_marginBottom="12dp"/>

    <!-- Save to Downloads Button -->
    <Button
        android:id="@+id/btnSaveToDownloads"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Save to Downloads"
        android:textColor="#2196F3"
        android:textSize="16sp"
        android:textStyle="bold"
        style="?android:attr/borderlessButtonStyle"
        android:layout_marginBottom="12dp"/>

    <!-- Done Button -->
    <Button
        android:id="@+id/btnDone"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Done"
        android:textColor="#757575"
        android:textSize="16sp"
        style="?android:attr/borderlessButtonStyle"
        android:layout_marginTop="8dp"/>

</LinearLayout>