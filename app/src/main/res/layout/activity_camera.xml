<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ── CAMERA PREVIEW CONTAINER ───────────────────────────── -->
    <FrameLayout
        android:id="@+id/cameraPreviewCard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="72dp"
        android:layout_marginBottom="192dp"
        android:background="@drawable/bg_camera_preview"
        android:clipToOutline="true">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fillCenter" />

        <!-- ── Anchor detection overlay ─────────────────────── -->
        <com.example.omrscanner.camera.AnchorOverlayView
            android:id="@+id/anchorOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- ── Grid overlay ──────────────────────────────────── -->
        <FrameLayout
            android:id="@+id/gridOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <View
                android:id="@+id/gridHLine1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_gravity="top"
                android:layout_marginTop="0dp" />

            <View
                android:id="@+id/gridHLine2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF" />

            <View
                android:id="@+id/gridVLine1"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#33FFFFFF"
                android:layout_gravity="start" />

            <View
                android:id="@+id/gridVLine2"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#33FFFFFF" />

        </FrameLayout>

        <!-- REMOVED: scanFrame anchor box — it served no functional purpose -->
        <!-- REMOVED: scanHintText — no longer needed without scan frame -->

        <!-- ── Top camera controls ───────── -->
        <LinearLayout
            android:id="@+id/topCameraControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal"
            android:gravity="end">

            <FrameLayout
                android:id="@+id/btnFlash"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_cam_ctrl_inactive"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/toggle_desc">
                <ImageView
                    android:id="@+id/iconFlash"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_flash"
                    app:tint="#CCFFFFFF" />
            </FrameLayout>

        </LinearLayout>

        <!-- ── Anchor detection status hint ──────────────────────── -->
        <LinearLayout
            android:id="@+id/anchorStatusBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#B3000000"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/anchorStatusIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_focus"
                app:tint="#FFC107" />

            <TextView
                android:id="@+id/anchorStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scanning for anchors…"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_medium"
                android:gravity="center" />

        </LinearLayout>

        <!-- ── Floating guidance hint (centered on preview) ──── -->
        <TextView
            android:id="@+id/floatingHintText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_floating_hint"
            android:text="Point camera at the OMR sheet"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium"
            android:gravity="center"
            android:maxWidth="280dp"
            android:visibility="visible"
            android:elevation="4dp" />

        <!-- ── Zoom slider bar removed ──────────────────────────────────── -->

    </FrameLayout>

    <!-- ── HEADER ROW ──────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/cameraHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <!-- FIXED: Back button now calls finish() once and returns directly to the caller -->
        <FrameLayout
            android:id="@+id/btnCameraBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_cam_btn_white"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/back">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/camera_capture"
            android:textColor="#E6FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />

    </LinearLayout>

    <!-- ── BOTTOM CONTROLS ─────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_fade"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="32dp">

        <!-- Zoom pills removed -->

        <!-- Main action row: capture ring -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Capture button: outer ring + inner disc -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_horizontal">

                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_capture_ring" />

                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_capture_glow"
                    android:alpha="0.30" />

                <FrameLayout
                    android:id="@+id/btnCapture"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_capture_disc"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/capture_desc">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_focus"
                        app:tint="#B3FFFFFF" />
                </FrameLayout>

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ── FLASH OVERLAY ───────────────────────────────────────── -->
    <View
        android:id="@+id/flashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFFFF"
        android:alpha="0"
        android:visibility="invisible" />

    <!-- ── ORIENTATION GUIDE OVERLAY ─────────────────────────────
         Shown when the phone is in portrait; tells user to rotate
         to landscape for scanning. Covers everything.
         ──────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/orientationGuideOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_orientation_overlay"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/orientationIcon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_rotate_phone"
            android:layout_marginBottom="20dp"
            android:contentDescription="@string/rotate_phone_desc" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rotate your phone"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_medium"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hold your phone in landscape mode\nto scan the OMR sheet"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

</FrameLayout>